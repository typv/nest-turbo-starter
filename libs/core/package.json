{
  "name": "@app/core",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:clean": "rimraf dist && pnpm build",
    "build": "npx tsc -p tsconfig.json",
    "start:dev": "npx tsc -p tsconfig.json --watch --preserveWatchOutput"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./*": {
      "import": "./dist/*.js",
      "require": "./dist/*.js"
    }
  },
  "dependencies": {
    "@app/common": "workspace:*",
    "@nestjs/common": "11.1.19",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "11.1.19",
    "@nestjs/microservices": "11.1.19",
    "@nestjs/passport": "^11.0.5",
    "rxjs": "^7.8.1",
    "lodash": "4.18.1",
    "@aws-sdk/client-s3": "^3.821.0",
    "@aws-sdk/client-ses": "^3.808.0",
    "@aws-sdk/s3-request-presigner": "^3.821.0",
    "nest-winston": "^1.10.2",
    "passport": "^0.7.0",
    "passport-custom": "^1.1.1",
    "winston": "^3.17.0",
    "firebase-admin": "^13.5.0",
    "google-auth-library": "^9.15.1",
    "axios": "1.15.0",
    "ioredis": "^5.6.1",
    "@mikro-orm/core": "7.0.10",
    "@mikro-orm/postgresql": "7.0.10",
    "@mikro-orm/decorators": "7.0.10",
    "class-transformer": "^0.5.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "typescript": "latest"
  }
}
